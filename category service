import { PrismaClient } from '@prisma/client';
import { CategoryResponse, WordResponse } from '../types';

const prisma = new PrismaClient();

export async function getAllCategories(): Promise<CategoryResponse[]> {
  const categories = await prisma.category.findMany({
    include: {
      _count: { select: { words: true } },
    },
    orderBy: { name: 'asc' },
  });

  return categories.map((cat: { id: string; name: string; _count: { words: number } }) => ({
    id: cat.id,
    name: cat.name,
    wordCount: cat._count.words,
  }));
}

export async function getCategoryWords(categoryId: string): Promise<WordResponse[]> {
  const words = await prisma.word.findMany({
    where: { categoryId },
    select: { id: true, value: true },
  });
  return words;
}

export async function createCategory(name: string): Promise<CategoryResponse> {
  const existing = await prisma.category.findUnique({ where: { name } });
  if (existing) {
    throw new Error(`Category "${name}" already exists`);
  }

  const category = await prisma.category.create({
    data: { name, isCustom: true },
    include: { _count: { select: { words: true } } },
  });

  return { id: category.id, name: category.name, wordCount: 0 };
}

export async function addWordToCategory(
  categoryId: string,
  value: string
): Promise<WordResponse> {
  const category = await prisma.category.findUnique({ where: { id: categoryId } });
  if (!category) throw new Error('Category not found');

  const word = await prisma.word.create({
    data: { value, categoryId },
    select: { id: true, value: true },
  });

  return word;
}
